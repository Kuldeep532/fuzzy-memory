<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ── Network ─────────────────────────────────────────────────────────
         Used by: AI Image Generator (Pollinations API), News & ePapers (RSS),
                  Speed Test, URL Shortener, Translator, Aira AI.
         NOT used for music streaming — all audio is played from local device storage.
    -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- ── Camera ──────────────────────────────────────────────────────────
         Used by: Object Detector, Colour Detector, Voice Typer (camera preview).
         Declared as not required — app is fully functional without camera.
    -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <!-- Flashlight — uses Camera2 torch mode; CAMERA permission covers this. -->

    <!-- ── Storage / Media ─────────────────────────────────────────────────
         Used by: Nexus Media Player (local audio), Smart Image Editor,
                  Doc Hub, File Manager, PDF Suite.
         READ_EXTERNAL_STORAGE limited to API ≤32; READ_MEDIA_* covers API 33+.
         WRITE_EXTERNAL_STORAGE limited to API ≤28 (scoped storage on 29+).
    -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" android:maxSdkVersion="28" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />

    <!-- ── Vibration ────────────────────────────────────────────────────────
         Used by: Morse Code (haptic output of dots and dashes).
    -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- ── Microphone ───────────────────────────────────────────────────────
         Used by: Voice Recorder (audio capture), Voice Typer (speech-to-text).
         Requested at runtime; never accessed without explicit user action.
    -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- ── Location ─────────────────────────────────────────────────────────
         Used by: Speedometer (GPS speed), Compass (magnetic bearing),
                  Wi-Fi Analyzer (nearby networks).
         FINE required for GPS accuracy in Speedometer.
         Requested at runtime; not collected or transmitted remotely.
    -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- ── Wi-Fi ─────────────────────────────────────────────────────────────
         Used by: Wi-Fi Analyzer (scan nearby networks and display signal info).
         Declared as not required — app functions without Wi-Fi hardware.
    -->
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />
    <uses-feature android:name="android.hardware.wifi" android:required="false" />

    <!-- ── Foreground Service / Media Playback ──────────────────────────────
         Used by: Nexus Media Player (background playback of local audio files).
         FOREGROUND_SERVICE_MEDIA_PLAYBACK is the correct type for audio.
         WAKE_LOCK ensures uninterrupted playback when screen is off.
         POST_NOTIFICATIONS required on API 33+ for the playback notification.
    -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- ── Accessibility Service ─────────────────────────────────────────────
         Used by: Nexus Speech Engine Screen Reader (reads on-screen text aloud).
         Declared as a system accessibility service; user must enable it manually.
    -->
    <uses-permission android:name="android.permission.BIND_ACCESSIBILITY_SERVICE" />

    <!-- ── Biometrics ────────────────────────────────────────────────────────
         Used by: Biometric Vault (fingerprint / face unlock to access vault).
         USE_FINGERPRINT kept for API <28 compatibility.
         No biometric data is stored by Nexus Plus — authentication is delegated
         entirely to the Android BiometricPrompt API.
    -->
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />
    <uses-permission android:name="android.permission.USE_FINGERPRINT" />
    <uses-feature android:name="android.hardware.fingerprint" android:required="false" />

    <!-- ── Emergency Guardian ────────────────────────────────────────────────
         Used by: Emergency Guardian (SOS — sends SMS with location to contacts).
         SEND_SMS is used ONLY when user explicitly activates SOS mode.
         FOREGROUND_SERVICE_LOCATION keeps GPS active during an SOS event.
         These permissions are critical safety features — not used for advertising
         or tracking.
    -->
    <uses-permission android:name="android.permission.SEND_SMS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />

    <!-- ── Contacts & Phone ─────────────────────────────────────────────────
         READ_CONTACTS used by: Nexus Dialer (browse device contacts), Contact Backup.
         CALL_PHONE used by: Nexus Dialer (initiate calls via system dialler).
         Neither permission is used for data collection or advertising.
    -->
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <uses-permission android:name="android.permission.CALL_PHONE" />

    <!-- ── Package Visibility (API 30+) ──────────────────────────────────────
         Used by: Installed Apps screen (AppInfoCenterScreen) — enumerates all
         user-installed packages to show name, version, size, and install date.
         QUERY_ALL_PACKAGES is required on Android 11+ for complete package list.
         No package data is transmitted or stored beyond the device.
    -->
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission" />

    <!-- ── Exact Alarms ──────────────────────────────────────────────────────
         Used by: My Reminder, Alarm Clock (fire alerts at precise user-set times).
         RECEIVE_BOOT_COMPLETED restores pending reminders after device restart.
         USE_EXACT_ALARM declared for API 33+; SCHEDULE_EXACT_ALARM for API 31-32.
    -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <application
        android:name=".NexusPlusApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.NexusPlus"
        android:largeHeap="true"
        android:networkSecurityConfig="@xml/network_security_config">

        <!-- Unity Ads does not require manifest meta-data entries.
             Initialization happens programmatically in NexusPlusApplication.onCreate(). -->

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.NexusPlus"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Share text / URL into Nexus Plus from any app -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>
            <!-- Share images from Gallery or other apps -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="image/*" />
            </intent-filter>
            <!-- Open PDF files (PDF Suite) -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="application/pdf" />
            </intent-filter>
            <!-- Open local audio files (Nexus Media Player) -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="audio/*" />
            </intent-filter>
            <!-- Open local video files (Nexus Media Player) -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="video/*" />
            </intent-filter>
            <!-- Open document files (Nexus Document Reader) -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
                <data android:mimeType="text/markdown" />
                <data android:mimeType="application/msword" />
                <data android:mimeType="application/vnd.openxmlformats-officedocument.wordprocessingml.document" />
            </intent-filter>
        </activity>

        <!-- Nexus Media Player — Media3 background playback service (local files only) -->
        <service
            android:name=".features.music.NexusPlaybackService"
            android:exported="true"
            android:foregroundServiceType="mediaPlayback"
            android:permission="android.permission.FOREGROUND_SERVICE">
            <intent-filter>
                <action android:name="androidx.media3.session.MediaSessionService" />
            </intent-filter>
        </service>

        <!-- Alarm Clock — BroadcastReceiver for exact alarm triggers -->
        <receiver
            android:name=".features.alarm.AlarmReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.nexuswavetech.nexusplus.ALARM_TRIGGER" />
            </intent-filter>
        </receiver>

        <!-- WorkManager boot receiver — restores pending My Reminder jobs after reboot -->
        <receiver
            android:name="androidx.work.impl.utils.ForceStopRunnable$BroadcastReceiver"
            android:enabled="true"
            android:exported="false" />

        <!-- Nexus Speech Engine (NSE) — registered as a system TTS provider -->
        <service
            android:name=".features.tts.NseTtsService"
            android:label="Nexus Speech Engine"
            android:exported="true"
            android:permission="android.permission.BIND_TEXT_TO_SPEECH_SERVICE">
            <intent-filter>
                <action android:name="android.intent.action.TTS_SERVICE" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
            <meta-data
                android:name="android.speech.tts"
                android:resource="@xml/tts_engine" />
        </service>

        <!-- Emergency Guardian — persistent SOS foreground service with location -->
        <service
            android:name=".features.emergencyguardian.EmergencyGuardianService"
            android:exported="false"
            android:foregroundServiceType="location"
            android:permission="android.permission.FOREGROUND_SERVICE">
            <intent-filter>
                <action android:name="com.nexuswavetech.nexusplus.EMERGENCY_GUARDIAN" />
            </intent-filter>
        </service>

        <!-- Nexus Speech Engine Screen Reader — Accessibility Service for reading screen content aloud -->
        <service
            android:name=".features.tts.NseAccessibilityService"
            android:label="Nexus Speech Engine Screen Reader"
            android:description="@string/nse_accessibility_desc"
            android:exported="true"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <!-- FileProvider — shares PDF files generated by Text to PDF feature via Intent.ACTION_SEND.
             Files are written to cacheDir/shared_pdfs/ and deleted when the cache is cleared.
             No user data is retained permanently by this provider. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_provider_paths" />
        </provider>

    </application>
</manifest>
